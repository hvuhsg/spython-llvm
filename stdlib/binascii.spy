# stdlib/binascii.spy — hex encoding/decoding and CRC-32.

@extern
def hexlify(s: str) -> str: ...

@extern
def unhexlify(s: str) -> str: ...

@extern
def crc32(s: str) -> int: ...

# b2a_hex / a2b_hex are CPython's alternate names for hexlify / unhexlify.
def b2a_hex(s: str) -> str:
    return hexlify(s)

def a2b_hex(s: str) -> str:
    return unhexlify(s)
