# stdlib/errno.spy — POSIX error number constants and their reverse mapping.
#
# CPython exposes errno values from the build host's <errno.h>, so the exact
# numbers vary across platforms (notably EAGAIN is 35 on Darwin/BSD and 11
# on Linux). This module's values are pinned to Darwin/macOS, matching the
# spython build host. To keep parity with CPython on a Linux build, swap
# this file for a Linux-pinned copy — the *names* are universal, only the
# integers differ.
#
# CPython's `errno` annotates `errorcode` as `dict[int, str]`; spython's
# generic-syntax for that type is `map[int, str]`. The runtime behavior
# (`errorcode[errno.ENOENT] == "ENOENT"`) is identical.

EPERM: int = 1
ENOENT: int = 2
ESRCH: int = 3
EINTR: int = 4
EIO: int = 5
ENXIO: int = 6
E2BIG: int = 7
ENOEXEC: int = 8
EBADF: int = 9
ECHILD: int = 10
EDEADLK: int = 11
ENOMEM: int = 12
EACCES: int = 13
EFAULT: int = 14
ENOTBLK: int = 15
EBUSY: int = 16
EEXIST: int = 17
EXDEV: int = 18
ENODEV: int = 19
ENOTDIR: int = 20
EISDIR: int = 21
EINVAL: int = 22
ENFILE: int = 23
EMFILE: int = 24
ENOTTY: int = 25
ETXTBSY: int = 26
EFBIG: int = 27
ENOSPC: int = 28
ESPIPE: int = 29
EROFS: int = 30
EMLINK: int = 31
EPIPE: int = 32
EDOM: int = 33
ERANGE: int = 34
EAGAIN: int = 35
EWOULDBLOCK: int = 35
EINPROGRESS: int = 36
EALREADY: int = 37
ENOTSOCK: int = 38
EDESTADDRREQ: int = 39
EMSGSIZE: int = 40
EPROTOTYPE: int = 41
ENOPROTOOPT: int = 42
EPROTONOSUPPORT: int = 43
ESOCKTNOSUPPORT: int = 44
ENOTSUP: int = 45
EPFNOSUPPORT: int = 46
EAFNOSUPPORT: int = 47
EADDRINUSE: int = 48
EADDRNOTAVAIL: int = 49
ENETDOWN: int = 50
ENETUNREACH: int = 51
ENETRESET: int = 52
ECONNABORTED: int = 53
ECONNRESET: int = 54
ENOBUFS: int = 55
EISCONN: int = 56
ENOTCONN: int = 57
ESHUTDOWN: int = 58
ETOOMANYREFS: int = 59
ETIMEDOUT: int = 60
ECONNREFUSED: int = 61
ELOOP: int = 62
ENAMETOOLONG: int = 63
EHOSTDOWN: int = 64
EHOSTUNREACH: int = 65
ENOTEMPTY: int = 66
EPROCLIM: int = 67
EUSERS: int = 68
EDQUOT: int = 69
ESTALE: int = 70
EREMOTE: int = 71
EBADRPC: int = 72
ERPCMISMATCH: int = 73
EPROGUNAVAIL: int = 74
EPROGMISMATCH: int = 75
EPROCUNAVAIL: int = 76
ENOLCK: int = 77
ENOSYS: int = 78
EFTYPE: int = 79
EAUTH: int = 80
ENEEDAUTH: int = 81
EPWROFF: int = 82
EDEVERR: int = 83
EOVERFLOW: int = 84
EBADEXEC: int = 85
EBADARCH: int = 86
ESHLIBVERS: int = 87
EBADMACHO: int = 88
ECANCELED: int = 89
EIDRM: int = 90
ENOMSG: int = 91
EILSEQ: int = 92
ENOATTR: int = 93
EBADMSG: int = 94
EMULTIHOP: int = 95
ENODATA: int = 96
ENOLINK: int = 97
ENOSR: int = 98
ENOSTR: int = 99
EPROTO: int = 100
ETIME: int = 101
EOPNOTSUPP: int = 102
ENOPOLICY: int = 103
ENOTRECOVERABLE: int = 104
EOWNERDEAD: int = 105
EQFULL: int = 106

errorcode: map[int, str] = {1: "EPERM", 2: "ENOENT", 3: "ESRCH", 4: "EINTR", 5: "EIO", 6: "ENXIO", 7: "E2BIG", 8: "ENOEXEC", 9: "EBADF", 10: "ECHILD", 11: "EDEADLK", 12: "ENOMEM", 13: "EACCES", 14: "EFAULT", 15: "ENOTBLK", 16: "EBUSY", 17: "EEXIST", 18: "EXDEV", 19: "ENODEV", 20: "ENOTDIR", 21: "EISDIR", 22: "EINVAL", 23: "ENFILE", 24: "EMFILE", 25: "ENOTTY", 26: "ETXTBSY", 27: "EFBIG", 28: "ENOSPC", 29: "ESPIPE", 30: "EROFS", 31: "EMLINK", 32: "EPIPE", 33: "EDOM", 34: "ERANGE", 35: "EAGAIN", 36: "EINPROGRESS", 37: "EALREADY", 38: "ENOTSOCK", 39: "EDESTADDRREQ", 40: "EMSGSIZE", 41: "EPROTOTYPE", 42: "ENOPROTOOPT", 43: "EPROTONOSUPPORT", 44: "ESOCKTNOSUPPORT", 45: "ENOTSUP", 46: "EPFNOSUPPORT", 47: "EAFNOSUPPORT", 48: "EADDRINUSE", 49: "EADDRNOTAVAIL", 50: "ENETDOWN", 51: "ENETUNREACH", 52: "ENETRESET", 53: "ECONNABORTED", 54: "ECONNRESET", 55: "ENOBUFS", 56: "EISCONN", 57: "ENOTCONN", 58: "ESHUTDOWN", 59: "ETOOMANYREFS", 60: "ETIMEDOUT", 61: "ECONNREFUSED", 62: "ELOOP", 63: "ENAMETOOLONG", 64: "EHOSTDOWN", 65: "EHOSTUNREACH", 66: "ENOTEMPTY", 67: "EPROCLIM", 68: "EUSERS", 69: "EDQUOT", 70: "ESTALE", 71: "EREMOTE", 72: "EBADRPC", 73: "ERPCMISMATCH", 74: "EPROGUNAVAIL", 75: "EPROGMISMATCH", 76: "EPROCUNAVAIL", 77: "ENOLCK", 78: "ENOSYS", 79: "EFTYPE", 80: "EAUTH", 81: "ENEEDAUTH", 82: "EPWROFF", 83: "EDEVERR", 84: "EOVERFLOW", 85: "EBADEXEC", 86: "EBADARCH", 87: "ESHLIBVERS", 88: "EBADMACHO", 89: "ECANCELED", 90: "EIDRM", 91: "ENOMSG", 92: "EILSEQ", 93: "ENOATTR", 94: "EBADMSG", 95: "EMULTIHOP", 96: "ENODATA", 97: "ENOLINK", 98: "ENOSR", 99: "ENOSTR", 100: "EPROTO", 101: "ETIME", 102: "EOPNOTSUPP", 103: "ENOPOLICY", 104: "ENOTRECOVERABLE", 105: "EOWNERDEAD", 106: "EQFULL"}
