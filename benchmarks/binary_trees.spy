class Tree:
    def __init__(self, depth: int):
        self.depth = depth
        if depth > 0:
            self.left = Tree(depth - 1)
            self.right = Tree(depth - 1)


def count(t: Tree) -> int:
    if t.depth == 0:
        return 1
    return 1 + count(t.left) + count(t.right)


N: int = 14
total: int = 0
i: int = 0
while i < 16:
    t: Tree = Tree(N)
    total = total + count(t)
    i = i + 1

print(total)
