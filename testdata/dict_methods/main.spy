d: map[str, int] = {"a": 1, "b": 2, "c": 3}
ks: list[str] = d.keys()
print(len(ks))
vs: list[int] = d.values()
print(len(vs))
ks.sort()
print(ks[0])
print(ks[1])
print(ks[2])
vs.sort()
print(vs[0])
print(vs[2])
print(d.get("a", 0))
print(d.get("z", -1))
e: map[str, int] = {"c": 30, "d": 4}
d.update(e)
print(len(d))
print(d.get("c", 0))
print(d.get("d", 0))
d.clear()
print(len(d))
print(d.get("a", 99))
