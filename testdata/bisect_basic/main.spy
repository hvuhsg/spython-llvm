from bisect import bisect_left, bisect_right, bisect, insort_left, insort_right, insort

a: list[int] = [1, 3, 3, 3, 5, 7]
print(bisect_left(a, 3))
print(bisect_right(a, 3))
print(bisect(a, 4))
print(bisect_left(a, 0))
print(bisect_right(a, 9))
print(0)

b: list[int] = [1, 2, 4, 5]
insort(b, 3)
print(b[0])
print(b[1])
print(b[2])
print(b[3])
print(b[4])
print(0)

ins: list[int] = [10, 20, 30]
insort_left(ins, 20)
print(ins[1])
print(ins[2])
print(0)

c: list[int] = [10, 20, 30, 40, 50]
print(bisect_left(c, 25, 1, 4))
print(0)

# genuine key=: array sorted by squared value; x lives in key-space
sq: list[int] = [1, 2, 3, 4]
print(bisect_left(sq, 9, 0, -1, lambda v: v * v))
print(bisect_right(sq, 4, 0, -1, lambda v: v * v))
