import math

print(math.comb(5, 2))
print(math.comb(10, 0))
print(math.comb(10, 10))
print(math.comb(52, 5))
print(math.perm(5, 2))
print(math.perm(5))
print(math.perm(5, 0))
print(math.isclose(1.0, 1.0))
print(math.isclose(1.0, 1.0000000001))
print(math.isclose(1.0, 1.1))
print(math.isclose(0.0, 0.0001, 0.0, 0.001))
print(math.prod([1.0, 2.0, 3.0, 4.0]))
print(math.prod([2.0, 3.0], 10.0))
print(math.dist([0.0, 0.0], [3.0, 4.0]))
print(math.remainder(10.0, 3.0))
print(math.nextafter(1.0, 2.0) > 1.0)
print(math.ulp(1.0) > 0.0)
m, ex = math.frexp(8.0)
print(m)
print(ex)
fr, ip = math.modf(3.75)
print(fr)
print(ip)
