import sys

# argv[0] is the program path. We don't know the exact path (it's a tempfile
# when invoked via `spython run`), but it must be non-empty.
args: list[str] = sys.argv()
print(len(args) >= 1)
print(len(args[0]) > 0)

# platform is one of the known values.
p: str = sys.platform()
is_known: bool = p == "darwin" or p == "linux" or p == "win32"
print(is_known)

# stdout_write emits without a trailing newline; chain two writes into one line.
sys.stdout_write("hello ")
sys.stdout_write("world")
print("")  # forces a newline
