import math

# Pre-existing surface — keep these so the regression target stays.
print(math.sqrt(16.0))
print(math.floor(3.7))
print(math.ceil(3.2))
print(math.fabs(-5.25))
print(math.pow(2.0, 10.0))
print(math.pi)

# Hyperbolic trig.
print(math.sinh(0.0))
print(math.cosh(0.0))
print(math.tanh(0.0))
print(math.asinh(0.0))
print(math.acosh(1.0))
print(math.atanh(0.0))

# Logs and exponentials.
print(math.exp(0.0))
print(math.expm1(0.0))
print(math.log1p(0.0))

# Rounding / sign / decomposition.
print(math.trunc(3.7))
print(math.trunc(-3.7))
print(math.copysign(5.0, -1.0))
print(math.ldexp(1.5, 3))   # 1.5 * 2^3 = 12

# Angle conversions — exact at multiples of pi.
print(math.degrees(math.pi))
print(math.radians(180.0))

# Special functions — spot-check a few exact / near-exact values.
print(math.gamma(5.0))      # 24
print(math.lgamma(1.0))     # 0
print(math.erf(0.0))
print(math.erfc(0.0))

# Predicates.
print(math.isfinite(1.0))
print(math.isfinite(math.inf))
print(math.isinf(math.inf))
print(math.isinf(1.0))
print(math.isnan(math.nan))
print(math.isnan(1.0))

# Constants.
print(math.tau)
# Direct print of inf/nan would require float-format support — just probe
# their identity via predicates above.

# Integer helpers.
print(math.factorial(0))
print(math.factorial(5))
print(math.factorial(10))
print(math.isqrt(0))
print(math.isqrt(15))
print(math.isqrt(16))
print(math.isqrt(99))
print(math.isqrt(100))

# Varargs gcd / lcm / hypot.
print(math.gcd())            # 0 (CPython identity)
print(math.gcd(12))
print(math.gcd(12, 18))
print(math.gcd(48, 18, 30))
print(math.gcd(7, 11, 13))   # coprime -> 1

print(math.lcm())            # 1 (CPython identity)
print(math.lcm(4))
print(math.lcm(4, 6))
print(math.lcm(2, 3, 4, 5))

print(math.hypot(3.0, 4.0))           # 5
print(math.hypot(1.0, 2.0, 2.0))      # 3
print(math.hypot(0.0))                # 0
