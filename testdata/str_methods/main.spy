s: str = "Hello, World"
print(s.upper())
print(s.lower())
print(s.startswith("Hello"))
print(s.endswith("World"))
print(s.find("World"))
print(s.rfind("o"))
print(s.count("l"))
print(s.replace("l", "L"))
print("  trim me  ".strip())
print("  trim me  ".lstrip())
print("42".zfill(5))
print("-42".zfill(5))
parts: list[str] = "a,b,c".split(",")
print(len(parts))
print(parts[0])
print(parts[2])
ws: list[str] = "  the  quick brown  ".split("")
print(len(ws))
print("-".join(parts))
print("123".isdigit())
print("abc".isalpha())
print("ABC".isupper())
print("hello world".capitalize())
