import os

# getpid is always a positive int.
pid: int = os.getpid()
print(pid > 0)

# getenv of a guaranteed-set var. PATH is set on any POSIX shell.
path: str = os.getenv("PATH")
print(len(path) > 0)

# getenv of an intentionally-unset var returns empty string.
missing: str = os.getenv("SPYTHON_TEST_DEFINITELY_UNSET_VAR_XYZ")
print(len(missing))

# Round-trip a directory create / listdir / remove dance.
base: str = "/tmp/spython_os_test_dir"

# Clean up any leftover from a prior failing run.
mode: int = os._stat_mode(base)
if mode >= 0:
    leftover: list[str] = os.listdir(base)
    i: int = 0
    while i < len(leftover):
        os.remove(base + "/" + leftover[i])
        i = i + 1
    os.rmdir(base)

os.mkdir(base)

# mkdir worked: stat now returns a valid mode.
print(os._stat_mode(base) >= 0)

# listdir on an empty dir is an empty list.
names: list[str] = os.listdir(base)
print(len(names))

# Cleanup.
os.rmdir(base)
print(os._stat_mode(base))  # -1 (ENOENT after removal)

# ----- Constants and metadata -----
print(os.sep)
print(os.linesep)
print(os.pathsep)
print(os.name)
print(os.curdir)
print(os.pardir)
print(os.devnull)

# F_OK is 0; the order R_OK > W_OK > X_OK > F_OK ensures the bit values
# don't collide.
print(os.F_OK)
print(os.X_OK)
print(os.W_OK)
print(os.R_OK)

# cpu_count is host-dependent — just check it's >= 1.
print(os.cpu_count() >= 1)

# Environment round-trip via setenv / getenv / unsetenv.
os.setenv("SPYTHON_OS_TEST_VAR", "hello")
print(os.getenv("SPYTHON_OS_TEST_VAR"))
os.unsetenv("SPYTHON_OS_TEST_VAR")
print(len(os.getenv("SPYTHON_OS_TEST_VAR")))  # 0 after unset

# umask: set to a known value, restore to whatever was there before.
prev: int = os.umask(18)   # 0o022
restored: int = os.umask(prev)
print(restored)             # 18 — proves we read back what we set

# access: /tmp must exist and be readable for any normal account.
print(os.access("/tmp", os.F_OK))
print(os.access("/tmp", os.R_OK))
print(os.access("/definitely/does/not/exist/xyz", os.F_OK))
