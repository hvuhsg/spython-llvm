nums: set[int] = {1, 2, 3, 2, 1}
print(len(nums))
print(2 in nums)
print(99 in nums)

nums.add(4)
nums.add(2)  # duplicate
print(len(nums))
print(4 in nums)

nums.discard(2)
print(len(nums))
print(2 in nums)

# Iterate. Order isn't guaranteed, so sum the values.
total: int = 0
for x in nums:
    total = total + x
print(total)

# String set + empty literal via annotation.
words: set[str] = {"hello", "world", "hello"}
print(len(words))
print("world" in words)
print("nope" in words)
print("world" not in words)
