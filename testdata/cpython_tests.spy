# ============ Nested if ============
val: int = 42
if val > 0:
    if val > 100:
        print("FAIL nested_if")
        failed += 1
    else:
        if val == 42:
            passed += 1
            print("PASS nested_if")
        else:
            failed += 1
            print("FAIL nested_if")

# ============ Nested loops ============
count: int = 0
for ni in range(5):
    for nj in range(5):
        count += 1
if count == 25:
    passed += 1
    print("PASS nested_loops")
else:
    failed += 1
    print("FAIL nested_loops")

# ============ Short-circuit and ============
sc_and: int = 0
if False and True:
    sc_and = 1
if sc_and == 0:
    passed += 1
    print("PASS short_circuit_and")
else:
    failed += 1
    print("FAIL short_circuit_and")

# ============ Short-circuit or ============
sc_or: int = 0
if True or False:
    sc_or = 1
if sc_or == 1:
    passed += 1
    print("PASS short_circuit_or")
else:
    failed += 1
    print("FAIL short_circuit_or")

# ============ Multiple function calls ============
def double(n: int) -> int:
    return n * 2

def add_one(n: int) -> int:
    return n + 1

if double(add_one(5)) == 12:
    passed += 1
    print("PASS nested_func_calls")
else:
    failed += 1
    print("FAIL nested_func_calls")

# ============ String escape sequences ============
if len("\n") == 1:
    passed += 1
    print("PASS escape_newline")
else:
    failed += 1
    print("FAIL escape_newline")

if len("\t") == 1:
    passed += 1
    print("PASS escape_tab")
else:
    failed += 1
