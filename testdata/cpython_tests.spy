# Tests derived from CPython test suite
# Each test prints "PASS" or "FAIL <description>"

passed: int = 0
failed: int = 0

# ============ test_augassign.py: testBasic ============
x: int = 2
x += 1
x *= 2
x **= 2
x -= 8
x //= 5
x %= 3
if x == 2:
    passed += 1
    print("PASS augassign_basic_int")
else:
    failed += 1
    print("FAIL augassign_basic_int")

# augmented assignment with bitwise
y: int = 2
y &= 3
if y == 2:
    passed += 1
    print("PASS augassign_and")
else:
    failed += 1
    print("FAIL augassign_and")

y |= 5
if y == 7:
    passed += 1
    print("PASS augassign_or")
else:
    failed += 1
    print("FAIL augassign_or")

y ^= 1
if y == 6:
    passed += 1
    print("PASS augassign_xor")
else:
    failed += 1
    print("FAIL augassign_xor")

