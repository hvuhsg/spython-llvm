# ============ For/range tests ============
total: int = 0
for i in range(10):
    total += i
if total == 45:
    passed += 1
    print("PASS range_sum")
else:
    failed += 1
    print("FAIL range_sum")

total2: int = 0
for j in range(5, 10):
    total2 += j
if total2 == 35:
    passed += 1
    print("PASS range_start_stop")
else:
    failed += 1
    print("FAIL range_start_stop")

total3: int = 0
for k in range(0, 20, 3):
    total3 += k
if total3 == 63:
    passed += 1
    print("PASS range_step")
else:
    failed += 1
    print("FAIL range_step")

# ============ While loop with break ============
counter: int = 0
w: int = 0
while True:
    if w == 5:
        break
    counter += 1
    w += 1
if counter == 5:
    passed += 1
    print("PASS while_break")
else:
    failed += 1
    print("FAIL while_break")

# ============ For with continue ============
evens: int = 0
for ci in range(10):
    if ci % 2 != 0:
        continue
    evens += 1
if evens == 5:
    passed += 1
    print("PASS for_continue")
else:
    failed += 1
    print("FAIL for_continue")

# ============ Recursive fibonacci ============
def fib(n: int) -> int:
    if n <= 1:
        return n
    return fib(n - 1) + fib(n - 2)

if fib(0) == 0:
    passed += 1
    print("PASS fib_0")
else:
    failed += 1
    print("FAIL fib_0")

if fib(1) == 1:
    passed += 1
    print("PASS fib_1")
else:
    failed += 1
    print("FAIL fib_1")

if fib(10) == 55:
    passed += 1
    print("PASS fib_10")
else:
    failed += 1
    print("FAIL fib_10")

