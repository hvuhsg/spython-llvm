# ============ test_binop.py: GCD algorithm ============
def gcd(aa: int, bb: int) -> int:
    while aa != 0:
        tmp: int = bb % aa
        bb = aa
        aa = tmp
    return bb

if gcd(10, 12) == 2:
    passed += 1
    print("PASS gcd_10_12")
else:
    failed += 1
    print("FAIL gcd_10_12")

if gcd(10, 15) == 5:
    passed += 1
    print("PASS gcd_10_15")
else:
    failed += 1
    print("FAIL gcd_10_15")

if gcd(10, 11) == 1:
    passed += 1
    print("PASS gcd_10_11")
else:
    failed += 1
    print("FAIL gcd_10_11")

if gcd(100, 15) == 5:
    passed += 1
    print("PASS gcd_100_15")
else:
    failed += 1
    print("FAIL gcd_100_15")

